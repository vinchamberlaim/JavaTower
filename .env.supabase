# Supabase Cloud Database Configuration
# Fill in your credentials after creating a free account at https://supabase.com

# Your Supabase project URL (e.g., https://abcdefgh.supabase.co)
SUPABASE_URL=

# Your Supabase anon/public API key (safe to use in client apps)
SUPABASE_ANON_KEY=

# Optional: Service role key for admin operations (keep secret!)
# SUPABASE_SERVICE_KEY=
